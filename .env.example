# Rohomieo environment variables (optional)
# Copy to .env.rohomieo or export in your shell.

# Signaling WebSocket URL (host + viewer)
ROHOMIEO_SIGNALING=wss://127.0.0.1:8443/ws

# Bind address for signaling server
ROHOMIEO_BIND=0.0.0.0:8443

# TLS certificate paths (signaling)
# ROHOMIEO_CERT=/path/to/cert.pem
# ROHOMIEO_KEY=/path/to/key.pem

# Host capture settings
ROHOMIEO_FPS=30
ROHOMIEO_IDLE_FPS=8
ROHOMIEO_DEVICE_NAME="My Laptop"

# Logging (tracing)
RUST_LOG=rohomieo_host=info,rohomieo_signaling=info,webrtc=warn

# Session TTL for stale signaling registrations (seconds)
ROHOMIEO_SESSION_TTL_SECS=3600

# Max PIN failures before temporary lockout
ROHOMIEO_MAX_PIN_FAILURES=5
